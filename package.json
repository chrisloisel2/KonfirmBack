{
	"name": "konfirm-backend",
	"version": "1.0.0",
	"description": "Backend API pour l'application de conformité LCB-FT Konfirm",
	"main": "dist/index.js",
	"scripts": {
		"dev": "nodemon src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"test": "jest --config jest.config.json",
		"test:watch": "jest --config jest.config.json --watch",
		"test:coverage": "jest --config jest.config.json --coverage",
		"test:unit": "jest --config jest.config.json --selectProjects=\"Unit Tests - Services LCB-FT\"",
		"test:integration": "jest --config jest.config.json --selectProjects=\"Integration Tests - API Routes\"",
		"test:e2e": "jest --config jest.config.json --selectProjects=\"E2E Tests - Workflow Complet\"",
		"test:lcbft": "npm run test:unit && npm run test:integration",
		"test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
		"test:ci": "jest --config jest.config.json --ci --coverage --watchAll=false",
		"lint": "eslint src/ --ext .ts",
		"db:seed": "ts-node src/database/seeders/index.ts",
		"db:setup": "npm run db:seed"
	},
	"dependencies": {
		"@prisma/client": "^5.22.0",
		"axios": "^1.5.0",
		"bcryptjs": "^2.4.3",
		"bull": "^4.11.3",
		"cheerio": "^1.2.0",
		"compression": "^1.7.4",
		"cors": "^2.8.5",
		"dotenv": "^16.3.1",
		"express": "^4.18.2",
		"express-rate-limit": "^6.10.0",
		"helmet": "^7.0.0",
		"ioredis": "^5.3.2",
		"joi": "^17.9.2",
		"jsonwebtoken": "^9.0.2",
		"lodash": "^4.17.21",
		"mindee": "^5.2.0",
		"moment": "^2.29.4",
		"mongodb": "^6.21.0",
		"morgan": "^1.10.0",
		"mrz": "^4.2.1",
		"multer": "^1.4.5-lts.1",
		"node-forge": "^1.4.0",
		"nodemailer": "^6.9.5",
		"passport": "^0.6.0",
		"passport-jwt": "^4.0.1",
		"passport-local": "^1.0.0",
		"pdf-lib": "^1.17.1",
		"pdf-parse": "^1.1.1",
		"redis": "^4.6.8",
		"sharp": "^0.32.6",
		"tesseract.js": "^4.1.4",
		"uuid": "^9.0.0",
		"winston": "^3.10.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.4",
		"@types/cheerio": "^0.22.35",
		"@types/compression": "^1.7.3",
		"@types/cors": "^2.8.14",
		"@types/express": "^4.17.17",
		"@types/jest": "^29.5.5",
		"@types/jsonwebtoken": "^9.0.3",
		"@types/lodash": "^4.14.199",
		"@types/morgan": "^1.9.6",
		"@types/multer": "^1.4.7",
		"@types/node": "^20.6.0",
		"@types/node-forge": "^1.3.14",
		"@types/nodemailer": "^6.4.11",
		"@types/passport": "^1.0.12",
		"@types/passport-jwt": "^3.0.9",
		"@types/passport-local": "^1.0.35",
		"@types/pdf-parse": "^1.1.5",
		"@types/supertest": "^2.0.13",
		"@types/uuid": "^9.0.4",
		"@typescript-eslint/eslint-plugin": "^6.7.2",
		"@typescript-eslint/parser": "^6.7.2",
		"eslint": "^8.49.0",
		"jest": "^29.7.0",
		"nodemon": "^3.0.1",
		"prisma": "^5.22.0",
		"supertest": "^6.3.3",
		"ts-jest": "^29.1.1",
		"ts-node": "^10.9.1",
		"typescript": "^5.2.2"
	},
	"engines": {
		"node": ">=20.0.0",
		"yarn": ">=1.22.0"
	}
}
